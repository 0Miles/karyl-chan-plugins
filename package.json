{
  "name": "karyl-chan-plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for karyl-chan-plugin-sdk and the official plugins (radio).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "build:sdk": "pnpm --filter @karyl-chan/plugin-sdk build",
    "test": "pnpm -r --filter './packages/*' test",
    "lint": "pnpm -r --filter './packages/*' --if-present lint",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0"
  }
}
