# 32-byte hex shared secret with karyl-chan (must match the bot's
# Per-plugin setup secret (optional). Generated by the bot admin via
# POST /api/plugins/setup-secret. When set, this takes priority over
# a per-plugin dispatchHmacKey used for HMAC verification of inbound
# KARYL_PLUGIN_SETUP_SECRET=

# (optional) override the bot URL when running outside the default
# docker-compose network.
# BOT_URL=http://karyl-chan:3000

# (optional) override the URL the bot uses to dispatch back to us.
# Defaults to http://karyl-radio-plugin:3000 (the docker hostname).
# PLUGIN_URL=http://karyl-radio-plugin:3000

# (optional) override the listen port. Default 3000.
# PORT=3000
