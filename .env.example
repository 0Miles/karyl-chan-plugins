# Host-side .env for docker-compose. Copy to .env and fill in.

# The radio service is profile-gated; without this `docker compose up`
# starts nothing.
COMPOSE_PROFILES=radio

# Per-plugin setup secret (32-byte hex). Provisioned via the bot admin
# API: POST /api/plugins/setup-secret { pluginKey: "karyl-radio" }. The
# bot stores its hash; the cleartext goes here and is never committed.
KARYL_PLUGIN_SETUP_SECRET_RADIO=

# Browser-reachable base URL for the radio WebUI (login link + play
# buttons). Defaults to http://localhost:903 (the compose port mapping)
# when left blank. The WebUI verifies plugin-session JWTs with the
# Ed25519 public key the bot hands it at register — no secret needed here.
RADIO_PUBLIC_URL=
