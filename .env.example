# Which plugins to start. Comma-separated profile names.
# Without this, `docker compose up` starts nothing (all services use profiles).
COMPOSE_PROFILES=radio

# Per-plugin setup secrets — one per plugin (32-byte hex each).
# Provisioned via bot admin API: POST /api/plugins/setup-secret
# with { pluginKey: "karyl-<key>" }. The bot stores its hash;
# the cleartext goes here and is never committed.

KARYL_PLUGIN_SETUP_SECRET_RADIO=

# Browser-reachable base URL for the radio WebUI (login link + play buttons).
# Defaults to http://localhost:903 (the docker port mapping) when unset.
# (The radio WebUI verifies plugin-session JWTs with the Ed25519 public key
#  the bot hands it at register — no shared secret needed here anymore.)
RADIO_PUBLIC_URL=
